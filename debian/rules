#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

ifneq ($(DEB_BUILD_GNU_TYPE),$(DEB_HOST_GNU_TYPE))
export CC=$(DEB_HOST_GNU_TYPE)-gcc
export CXX=$(DEB_HOST_GNU_TYPE)-g++
export PKG_CONFIG=/usr/bin/pkgconf
export PKG_CONFIG_LIBDIR=/usr/lib/$(DEB_HOST_MULTIARCH)/pkgconfig:/usr/share/pkgconfig
CROSS_CMAKE_ARGS = -DPKG_CONFIG_EXECUTABLE=/usr/bin/pkgconf -DPKGCONFIG_EXECUTABLE=/usr/bin/pkgconf
endif

ifneq (,$(filter nocheck,$(DEB_BUILD_OPTIONS)))
NOCHECK_CMAKE_ARGS = -DBUILD_TESTING=OFF
endif

%:
	dh $@ --buildsystem=cmake

override_dh_auto_configure:
	dh_auto_configure -- $(CROSS_CMAKE_ARGS) $(NOCHECK_CMAKE_ARGS)
